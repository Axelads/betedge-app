{
  "expo": {
    "name": "BetEdge",
    "slug": "betedge",
    "version": "1.0.0",
    "scheme": "betedge",
    "orientation": "portrait",
    "icon": "./assets/icon_appstore_white.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo_ecriture_betedge.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.betedge.app",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.betedge.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_betgde.png",
        "backgroundColor": "#1e40af"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "BetEdge accède à vos photos pour personnaliser votre avatar de profil.",
          "cameraPermission": "BetEdge accède à votre caméra pour prendre une photo de profil."
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "faf34846-b373-4872-880c-cd1aadf53553"
      }
    },
    "owner": "axelads"
  }
}
